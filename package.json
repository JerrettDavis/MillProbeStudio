{
  "name": "mill-probe-studio",
  "private": true,
  "version": "1.3.1",
  "type": "module",
  "description": "A modern web application for creating, managing, and visualizing CNC mill probe sequences with intelligent G-code generation",
  "keywords": [
    "cnc",
    "gcode",
    "mill",
    "probe",
    "machining",
    "typescript",
    "react",
    "3d-visualization"
  ],
  "homepage": "https://jerrettdavis.github.io/MillProbeStudio/",
  "repository": {
    "type": "git",
    "url": "https://github.com/JerrettDavis/MillProbeStudio.git"
  },
  "bugs": {
    "url": "https://github.com/JerrettDavis/MillProbeStudio/issues"
  },
  "author": {
    "name": "JDH Productions LLC",
    "email": "jd@jdhpro.com",
    "url": "https://jdhpro.com"
  },
  "license": "SEE LICENSE IN LICENSE.md",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:coverage:watch": "vitest --coverage",
    "test:report:junit": "vitest --reporter=junit --outputFile=test-report.junit.xml",
    "test:coverage:ui": "vitest --ui --coverage",
    "coverage:open": "start coverage/index.html",
    "coverage:clean": "rimraf coverage",
    "release": "semantic-release",
    "release:dry-run": "semantic-release --dry-run"
  },
